# Copy this file to .env and fill in real values. Do NOT commit .env.

# PostgreSQL
POSTGRES_USER=devtrack
POSTGRES_PASSWORD=ChangeMe_Strong!Pass123
POSTGRES_DB=devtrack
POSTGRES_HOST_PORT=5432

# API
API_HOST_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# JWT — Secret must be at least 32 characters of high-entropy randomness
JWT_ISSUER=DevTrack
JWT_AUDIENCE=DevTrack
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-chars
JWT_LIFETIME_DAYS=7

# AI extraction (LM Studio / Ollama / any OpenAI-compatible endpoint)
# host.docker.internal lets the API container reach the LM Studio running on the host machine.
AI_BASE_URL=http://host.docker.internal:1234/v1
AI_MODEL=llama-3.1-8b-instruct
AI_API_KEY=lm-studio
